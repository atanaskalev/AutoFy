<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoFy.Mobile.Views.AddReminderView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Напомняне"
    BackgroundColor="#F3F4F6">

    <ScrollView>
        <VerticalStackLayout
            Padding="20"
            Spacing="18">

            <VerticalStackLayout Spacing="4">
                <Label
                    Text="Добави напомняне"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#111827" />

                <Label
                    Text="{Binding VehicleName}"
                    FontSize="20"
                    TextColor="#6B7280" />
            </VerticalStackLayout>

            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24"
                Padding="16">

                <VerticalStackLayout Spacing="16">

                    <Picker
                        Title="Тип напомняне"
                        ItemsSource="{Binding ReminderTypes}"
                        SelectedItem="{Binding SelectedReminderType}" />

                    <DatePicker
                        Date="{Binding ReminderDate}" />

                    <Editor
                        Placeholder="Бележка"
                        AutoSize="TextChanges"
                        HeightRequest="120"
                        Text="{Binding Notes}" />

                </VerticalStackLayout>
            </Border>

            <Button
                Text="{Binding SaveButtonText}"
                HeightRequest="54"
                CornerRadius="18"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#F59E0B"
                TextColor="White"
                Command="{Binding SaveReminderCommand}" />

            <Button
                Text="Изтрий напомнянето"
                HeightRequest="54"
                CornerRadius="18"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="#DC2626"
                TextColor="White"
                IsVisible="{Binding IsEditMode}"
                Command="{Binding DeleteReminderCommand}" />
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
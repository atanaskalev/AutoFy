<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoFy.Mobile.Views.FuelHistoryView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="История на зареждания"
    BackgroundColor="#F3F4F6">

    <Grid>

        <CollectionView
            Margin="20"
            ItemsSource="{Binding FuelEntries}">

            <!-- Header -->
            <CollectionView.Header>

                <VerticalStackLayout
                    Spacing="4"
                    Margin="0,0,0,18">

                    <Label
                        Text="История на зареждания"
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="#111827" />

                    <Label
                        Text="{Binding VehicleName}"
                        FontSize="20"
                        TextColor="#6B7280" />

                </VerticalStackLayout>

            </CollectionView.Header>

            <!-- Empty -->
            <CollectionView.EmptyView>

                <VerticalStackLayout
                    Padding="0,80,0,0"
                    Spacing="12"
                    HorizontalOptions="Center">

                    <Label
                        Text="⛽"
                        FontSize="54"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Няма зареждания"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="#111827"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Добавените зареждания ще се появят тук."
                        FontSize="14"
                        TextColor="#6B7280"
                        HorizontalTextAlignment="Center"
                        MaximumWidthRequest="260" />

                </VerticalStackLayout>

            </CollectionView.EmptyView>

            <!-- Items -->
            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Border
                        Margin="0,0,0,14"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24">

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenEditFuelEntryCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        
                        <VerticalStackLayout Spacing="14">

                            <!-- Top -->
                            <Grid ColumnDefinitions="*,Auto">

                                <VerticalStackLayout Spacing="2">

                                    <Label
                                        Text="{Binding DateText}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="#111827" />

                                    <Label
                                        Text="{Binding OdometerText}"
                                        FontSize="13"
                                        TextColor="#6B7280" />

                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding TotalPriceText}"
                                    FontSize="20"
                                    FontAttributes="Bold"
                                    TextColor="#2563EB"
                                    VerticalOptions="Center" />

                            </Grid>

                            <!-- Stats -->
                            <Grid ColumnDefinitions="*,*,*"
                                  ColumnSpacing="10">

                                <Border
                                    BackgroundColor="#F3F4F6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10">

                                    <VerticalStackLayout Spacing="2">
                                        <Label
                                            Text="Литри"
                                            FontSize="12"
                                            TextColor="#6B7280" />

                                        <Label
                                            Text="{Binding LitersText}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="#111827" />
                                    </VerticalStackLayout>

                                </Border>

                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#F3F4F6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10">

                                    <VerticalStackLayout Spacing="2">
                                        <Label
                                            Text="Разход"
                                            FontSize="12"
                                            TextColor="#6B7280" />

                                        <Label
                                            Text="{Binding ConsumptionText}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="#111827" />
                                    </VerticalStackLayout>

                                </Border>

                                <Border
                                    Grid.Column="2"
                                    BackgroundColor="#F3F4F6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 16"
                                    Padding="10">

                                    <VerticalStackLayout Spacing="2">
                                        <Label
                                            Text="Цена/л"
                                            FontSize="12"
                                            TextColor="#6B7280" />

                                        <Label
                                            Text="{Binding PricePerLiterText}"
                                            FontSize="16"
                                            FontAttributes="Bold"
                                            TextColor="#111827" />
                                    </VerticalStackLayout>

                                </Border>

                            </Grid>

                            <!-- Note -->
                            <Label
                                Text="{Binding Notes}"
                                FontSize="13"
                                TextColor="#6B7280"
                                IsVisible="{Binding HasNotes}" />

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
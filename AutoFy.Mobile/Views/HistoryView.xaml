<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoFy.Mobile.Views.HistoryView"
    x:Name="HistoryPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="История"
    BackgroundColor="#F3F4F6">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
        EventName="Appearing"
        BindingContext="{Binding Source={x:Reference HistoryPage}, Path=BindingContext}"
        Command="{Binding InitializeCommand}" />
    </ContentPage.Behaviors>
    
    <Grid RowDefinitions="Auto,*" Padding="20">

        <VerticalStackLayout Spacing="14">

            <Label
                Text="История"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="#111827" />

            <Border
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 24"
                Padding="14">

                <VerticalStackLayout Spacing="12">

                    <Picker
                        Title="Автомобил"
                        ItemsSource="{Binding Vehicles}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        SelectedItem="{Binding SelectedVehicle}" />

                    <Picker
                        Title="Тип запис"
                        ItemsSource="{Binding HistoryTypes}"
                        SelectedItem="{Binding SelectedHistoryType}" />

                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                        <DatePicker
                            Date="{Binding SelectedDate}"
                            IsEnabled="{Binding UseDateFilter}" />

                        <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                            <Label
                                Text="Дата"
                                FontSize="13"
                                TextColor="#6B7280"
                                VerticalOptions="Center" />

                            <Switch IsToggled="{Binding UseDateFilter}" />
                        </HorizontalStackLayout>
                    </Grid>

                    <Button
                        Text="Изчисти филтрите"
                        HeightRequest="44"
                        CornerRadius="14"
                        BackgroundColor="#E5E7EB"
                        TextColor="#111827"
                        Command="{Binding ClearFiltersCommand}" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <CollectionView
            Grid.Row="1"
            Margin="0,18,0,0"
            ItemsSource="{Binding HistoryItems}">

            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Padding="0,80,0,0"
                    Spacing="12"
                    HorizontalOptions="Center">

                    <Label
                        Text="📋"
                        FontSize="54"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Няма записи"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="#111827"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Историята от зареждания и сервизни дейности ще се появи тук."
                        FontSize="14"
                        TextColor="#6B7280"
                        HorizontalTextAlignment="Center"
                        MaximumWidthRequest="280" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,0,14"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24">

                        <VerticalStackLayout Spacing="10">

                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="2">
                                    <Label
                                        Text="{Binding Title}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="#111827" />

                                    <Label
                                        Text="{Binding VehicleName}"
                                        FontSize="13"
                                        TextColor="#6B7280" />
                                </VerticalStackLayout>

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding AmountText}"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    TextColor="#2563EB"
                                    VerticalOptions="Center" />
                            </Grid>

                            <Grid ColumnDefinitions="Auto,*,Auto">
                                <Label
                                    Text="{Binding Type}"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    TextColor="#111827" />

                                <Label
                                    Grid.Column="1"
                                    Text="{Binding Subtitle}"
                                    FontSize="13"
                                    TextColor="#6B7280"
                                    Margin="10,0,10,0" />

                                <Label
                                    Grid.Column="2"
                                    Text="{Binding DateText}"
                                    FontSize="13"
                                    TextColor="#6B7280" />
                            </Grid>

                        </VerticalStackLayout>

                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
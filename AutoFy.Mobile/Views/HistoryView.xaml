<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoFy.Mobile.Views.HistoryView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="История"
    BackgroundColor="#F3F4F6">

    <Grid>

        <CollectionView
            Margin="20"
            ItemsSource="{Binding HistoryItems}">

            <CollectionView.Header>

                <VerticalStackLayout
                    Spacing="4"
                    Margin="0,0,0,18">

                    <Label
                        Text="История"
                        FontSize="30"
                        FontAttributes="Bold"
                        TextColor="#111827" />

                    <Label
                        Text="Всички зареждания, ремонти и дейности."
                        FontSize="14"
                        TextColor="#6B7280" />

                </VerticalStackLayout>

            </CollectionView.Header>

            <CollectionView.EmptyView>

                <VerticalStackLayout
                    Padding="0,80,0,0"
                    Spacing="12"
                    HorizontalOptions="Center">

                    <Label
                        Text="📂"
                        FontSize="52"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Все още няма история"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="#111827"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Добавените зареждания и сервизни дейности ще се появят тук."
                        FontSize="14"
                        TextColor="#6B7280"
                        HorizontalTextAlignment="Center"
                        MaximumWidthRequest="260" />

                </VerticalStackLayout>

            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>

                <DataTemplate>

                    <Border
                        Margin="0,0,0,14"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24">

                        <Grid ColumnDefinitions="60,*">

                            <!-- Icon -->
                            <Border
                                WidthRequest="52"
                                HeightRequest="52"
                                BackgroundColor="#E5E7EB"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 18"
                                VerticalOptions="Start">

                                <Label
                                    Text="{Binding Icon}"
                                    FontSize="26"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center" />

                            </Border>

                            <!-- Content -->
                            <VerticalStackLayout
                                Grid.Column="1"
                                Spacing="6">

                                <Grid ColumnDefinitions="*,Auto">

                                    <Label
                                        Text="{Binding Title}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="#111827" />

                                    <Label
                                        Grid.Column="1"
                                        Text="{Binding Price}"
                                        FontSize="16"
                                        FontAttributes="Bold"
                                        TextColor="#2563EB" />

                                </Grid>

                                <Label
                                    Text="{Binding Vehicle}"
                                    FontSize="14"
                                    TextColor="#6B7280" />

                                <Label
                                    Text="{Binding Date}"
                                    FontSize="13"
                                    TextColor="#9CA3AF" />

                            </VerticalStackLayout>

                        </Grid>

                    </Border>

                </DataTemplate>

            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
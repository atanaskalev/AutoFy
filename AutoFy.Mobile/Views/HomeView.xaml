<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoFy.Mobile.Views.HomeView"
    x:Name="HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#F3F4F6">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
        EventName="Appearing"
        BindingContext="{Binding Source={x:Reference HomePage}, Path=BindingContext}"
        Command="{Binding LoadVehiclesCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto,*" Padding="18">

        <!-- Top bar -->
        <Grid ColumnDefinitions="48,*,48" HeightRequest="56">

            <Border
                StrokeThickness="0"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 18">

                <Button
                    Text="ℹ"
                    FontSize="22"
                    TextColor="#111827"
                    BackgroundColor="Transparent"
                    Command="{Binding OpenAboutCommand}" />
            </Border>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center">
                <Label
                    Text="AutoFy"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#111827"
                    HorizontalTextAlignment="Center" />

                <Label
                    Text="Твоят автомобилен дневник"
                    FontSize="12"
                    TextColor="#6B7280"
                    HorizontalTextAlignment="Center" />
            </VerticalStackLayout>

            <Border
                Grid.Column="2"
                StrokeThickness="0"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 18">

                <Button
                    Text="☰"
                    FontSize="24"
                    TextColor="#111827"
                    BackgroundColor="Transparent"
                    Command="{Binding OpenMenuCommand}" />
            </Border>
        </Grid>

        <!-- Main content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="18" Padding="0,20,0,90">

                <Grid ColumnDefinitions="*,Auto">
                    <Label
                        Text="Моите автомобили"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#111827"
                        VerticalOptions="Center" />

                    <Label
                        Grid.Column="1"
                        Text="{Binding VehiclesCount}"
                        FontSize="14"
                        TextColor="#6B7280"
                        VerticalOptions="Center" />
                </Grid>

                <CollectionView ItemsSource="{Binding Vehicles}">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border
                                StrokeThickness="0"
                                BackgroundColor="White"
                                StrokeShape="RoundRectangle 24"
                                Padding="14"
                                Margin="0,0,0,14">

                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenVehicleDetailsCommand}"
                                        CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>

                                <Grid ColumnDefinitions="96,*" ColumnSpacing="14">

                                    <Border
                                        WidthRequest="88"
                                        HeightRequest="88"
                                        BackgroundColor="#E5E7EB"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 20">

                                        <Image
                                            Source="{Binding ImagePath}"
                                            Aspect="AspectFill"
                                            WidthRequest="88"
                                            HeightRequest="88" />
                                    </Border>

                                    <VerticalStackLayout Grid.Column="1" Spacing="5">

                                        <Label
                                            Text="{Binding DisplayName}"
                                            FontSize="20"
                                            FontAttributes="Bold"
                                            TextColor="#111827" />

                                        <Label
                                            Text="{Binding ShortInfo}"
                                            FontSize="14"
                                            TextColor="#6B7280" />

                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Floating Add Button -->
        <Border
            Grid.Row="1"
            WidthRequest="64"
            HeightRequest="64"
            Margin="0,0,8,18"
            BackgroundColor="#2563EB"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 32"
            HorizontalOptions="End"
            VerticalOptions="End">

            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding OpenAddVehicleCommand}" />
            </Border.GestureRecognizers>

            <Label
                Text="+"
                FontSize="38"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center"
                VerticalOptions="Center" />
        </Border>

    </Grid>
</ContentPage>
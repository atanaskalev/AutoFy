<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AutoFy.Mobile.Views.StatisticsView"
    x:Name="StatisticsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    Title="Статистика"
    BackgroundColor="#F3F4F6">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            BindingContext="{Binding Source={x:Reference StatisticsPage}, Path=BindingContext}"
            Command="{Binding LoadStatisticsCommand}" />
    </ContentPage.Behaviors>

    <Grid Padding="20" RowDefinitions="Auto,*">

        <VerticalStackLayout Spacing="14">

            <Label
                Text="Статистика"
                FontSize="30"
                FontAttributes="Bold"
                TextColor="#111827" />

            <Border
                BackgroundColor="#111827"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 28"
                Padding="20">

                <VerticalStackLayout Spacing="6">

                    <Label
                        Text="Общо разходи по всички автомобили"
                        FontSize="14"
                        TextColor="#D1D5DB" />

                    <Label
                        Text="{Binding TotalCostText}"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="White" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <CollectionView
            Grid.Row="1"
            Margin="0,18,0,0"
            ItemsSource="{Binding Vehicles}">

            <CollectionView.EmptyView>
                <VerticalStackLayout
                    Padding="0,80,0,0"
                    Spacing="12"
                    HorizontalOptions="Center">

                    <Label
                        Text="📊"
                        FontSize="54"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Няма статистика"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="#111827"
                        HorizontalTextAlignment="Center" />

                    <Label
                        Text="Добави автомобил, зареждания или сервизни дейности, за да се появят данни."
                        FontSize="14"
                        TextColor="#6B7280"
                        HorizontalTextAlignment="Center"
                        MaximumWidthRequest="280" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border
                        Margin="0,0,0,14"
                        Padding="16"
                        BackgroundColor="White"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24">

                        <VerticalStackLayout Spacing="14">

                            <Label
                                Text="{Binding VehicleName}"
                                FontSize="20"
                                FontAttributes="Bold"
                                TextColor="#111827" />

                            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">

                                <Border
                                    BackgroundColor="#F3F4F6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="12">

                                    <VerticalStackLayout Spacing="4">
                                        <Label
                                            Text="Общо разходи"
                                            FontSize="13"
                                            TextColor="#6B7280" />

                                        <Label
                                            Text="{Binding TotalCostText}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="#111827" />
                                    </VerticalStackLayout>
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    BackgroundColor="#F3F4F6"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    Padding="12">

                                    <VerticalStackLayout Spacing="4">
                                        <Label
                                            Text="Среден разход"
                                            FontSize="13"
                                            TextColor="#6B7280" />

                                        <Label
                                            Text="{Binding AverageFuelConsumptionText}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="#111827" />
                                    </VerticalStackLayout>
                                </Border>

                            </Grid>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>